{
  "expo": {
    "name": "TaxShax",
    "slug": "itaxeasy-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon_48.png",
    "scheme": "itaxeasyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icon2_padded.png",
        "monochromeImage": "./assets/images/icon2_padded.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.itaxeasy.TaxShax"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon_48.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon2.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      [
        "./plugins/withReactNativeArchitectures",
        {
          "architectures": "arm64-v8a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52aca66f-6cbe-4cb3-8e89-47d6cb2ca773"
      }
    },
    "owner": "akshatgg"
  }
}
