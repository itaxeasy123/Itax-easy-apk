{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.itaxeasy.com/api",
        "EXPO_PUBLIC_OCR_API_BASE_URL": "https://ocr.itaxeasy.com/api",
        "EXPO_PUBLIC_APK_API_BASE_URL": "https://apk-api.itaxeasy.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.itaxeasy.com/api",
        "EXPO_PUBLIC_OCR_API_BASE_URL": "https://ocr.itaxeasy.com/api",
        "EXPO_PUBLIC_APK_API_BASE_URL": "https://apk-api.itaxeasy.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
